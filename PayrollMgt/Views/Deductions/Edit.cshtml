            <div class="form-group">
                <label asp-for="DeductionType" class="control-label"></label>
                <input asp-for="DeductionType" class="form-control" />
                <span asp-validation-for="DeductionType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateOfDeduction" class="control-label"></label>
                <input asp-for="DateOfDeduction" class="form-control" />
                <span asp-validation-for="DateOfDeduction" class="text-danger"></span>
